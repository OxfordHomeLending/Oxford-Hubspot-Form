# Copy this file to ".env" and adjust as needed. Vite only exposes vars
# prefixed with VITE_ to the browser bundle.

# Your n8n production webhook (POST). The app falls back to this value if the
# variable is not set, so the form works out of the box.
# IMPORTANT: for a live https embed (GitHub Pages / Webflow), this MUST be https
# or the browser will block the request as mixed content. Put n8n behind TLS
# (Caddy / Nginx + Let's Encrypt, or a Cloudflare Tunnel) and use that URL here.
VITE_N8N_WEBHOOK_URL=http://174.138.67.21:5678/webhook/0677cb4f-76a7-46ba-b9ad-40d030d43c59

# Optional. If set, the form redirects here on success instead of showing the
# inline thank-you screen.
VITE_REDIRECT_URL=

# Optional shared secret. If set, the form sends it as an "X-Oxford-Form-Token"
# header and your n8n flow can reject any POST that lacks it. Note: anything in
# the browser bundle is readable by a determined user, so treat this as a filter
# against casual abuse, not a true secret. Combine it with CORS + the honeypot.
VITE_FORM_TOKEN=
